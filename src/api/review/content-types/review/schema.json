{
  "kind": "collectionType",
  "collectionName": "reviews",
  "info": { "singularName": "review", "pluralName": "reviews", "displayName": "Review" },
  "options": { "draftAndPublish": true },
  "attributes": {
    "name": { "type": "string", "required": true },
    "role": { "type": "string" },
    "text": { "type": "text", "required": true },
    "rating": { "type": "integer", "min": 1, "max": 5 },
    "course": { "type": "relation", "relation": "manyToOne", "target": "api::course.course", "inversedBy": "reviews" }
  }
}
