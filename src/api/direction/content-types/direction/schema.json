{
  "kind": "collectionType",
  "collectionName": "directions",
  "info": { "singularName": "direction", "pluralName": "directions", "displayName": "Direction" },
  "options": { "draftAndPublish": true },
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "description": { "type": "text" },
    "icon": { "type": "string" },
    "order": { "type": "integer", "default": 0 },
    "courses": { "type": "relation", "relation": "oneToMany", "target": "api::course.course", "mappedBy": "direction" }
  }
}
